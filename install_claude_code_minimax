#!/bin/bash
# 一键安装 Claude Code (Minimax 国际版) - 幂等版本
# 适用于 Linux，需要 sudo 权限
# 用法:
#   ./install-claude-minimax.sh                 # 交互式输入 API Key
#   MINIMAX_API_KEY=your_key ./install-claude-minimax.sh   # 非交互式

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${GREEN}=== Claude Code 安装与配置 (Minimax 国际版) ===${NC}"

# ---------- 函数定义 ----------
check_command() {
    command -v "$1" &> /dev/null
}

get_existing_api_key() {
    # 尝试从已有 settings.json 中提取 API Key
    local settings_file="$HOME/.claude/settings.json"
    if [ -f "$settings_file" ]; then
        # 使用 grep 和 sed 提取，兼容 JSON 格式变化
        grep -o '"ANTHROPIC_AUTH_TOKEN"[[:space:]]*:[[:space:]]*"[^"]*"' "$settings_file" 2>/dev/null | \
            sed -E 's/.*"([^"]+)"$/\1/' | head -1
    fi
}

backup_file() {
    local file="$1"
    if [ -f "$file" ]; then
        local backup="${file}.backup.$(date +%Y%m%d_%H%M%S)"
        cp "$file" "$backup"
        echo -e "${YELLOW}已备份: $file -> $backup${NC}"
    fi
}

# ---------- 1. 环境检查 ----------
echo -e "${YELLOW}[1/5] 检查运行环境...${NC}"

# 检查 Node.js 和 npm
if ! check_command node; then
    echo -e "${RED}错误: Node.js 未安装。请先安装 Node.js 18+。${NC}"
    echo -e "Ubuntu/Debian: curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - && sudo apt install -y nodejs"
    echo -e "CentOS/RHEL: curl -fsSL https://rpm.nodesource.com/setup_20.x | sudo bash - && sudo yum install -y nodejs"
    exit 1
fi

NODE_VERSION=$(node -v | cut -d'v' -f2 | cut -d'.' -f1)
if [ "$NODE_VERSION" -lt 18 ]; then
    echo -e "${RED}错误: Node.js 版本过低 (需要 >= 18)。当前版本: $(node -v)${NC}"
    exit 1
fi

if ! check_command npm; then
    echo -e "${RED}错误: npm 未安装。${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Node.js $(node -v) / npm $(npm -v)${NC}"

# 检查 sudo 权限（非 root 时）
if [ "$EUID" -ne 0 ] && ! sudo -n true 2>/dev/null; then
    echo -e "${YELLOW}提示: 需要 sudo 权限进行全局安装。${NC}"
fi

# ---------- 2. 获取 API Key ----------
echo -e "${YELLOW}[2/5] API Key 配置...${NC}"

# 支持环境变量传入（适合 CI/CD）
if [ -n "$MINIMAX_API_KEY" ]; then
    API_KEY="$MINIMAX_API_KEY"
    echo -e "${GREEN}✓ 从环境变量 MINIMAX_API_KEY 读取 API Key${NC}"
else
    EXISTING_KEY=$(get_existing_api_key)
    if [ -n "$EXISTING_KEY" ]; then
        echo -e "${BLUE}检测到已有 API Key (${EXISTING_KEY:0:8}...)，是否沿用？${NC}"
        read -r -p "[Y/n] " USE_EXISTING
        if [[ "$USE_EXISTING" =~ ^[Nn]$ ]]; then
            read -r -p "请输入新的 MiniMax API Key: " API_KEY
        else
            API_KEY="$EXISTING_KEY"
            echo -e "${GREEN}✓ 使用已有 API Key${NC}"
        fi
    else
        read -r -p "请输入 MiniMax API Key: " API_KEY
    fi
fi

if [ -z "$API_KEY" ]; then
    echo -e "${RED}错误: API Key 不能为空。${NC}"
    exit 1
fi

# ---------- 3. 安装/更新 Claude Code ----------
echo -e "${YELLOW}[3/5] 安装 @anthropic-ai/claude-code...${NC}"

INSTALL_NEEDED=true
if check_command claude; then
    CURRENT_VERSION=$(claude --version 2>/dev/null | head -1 || echo "unknown")
    echo -e "${BLUE}检测到已安装的 Claude Code: ${CURRENT_VERSION}${NC}"
    read -r -p "是否重新安装/更新？ [y/N] " REINSTALL
    if [[ ! "$REINSTALL" =~ ^[Yy]$ ]]; then
        INSTALL_NEEDED=false
        echo -e "${GREEN}✓ 跳过安装，保持现有版本${NC}"
    fi
fi

if [ "$INSTALL_NEEDED" = true ]; then
    echo -e "正在执行: sudo npm install -g @anthropic-ai/claude-code"
    if sudo npm install -g @anthropic-ai/claude-code; then
        echo -e "${GREEN}✓ Claude Code 安装/更新完成${NC}"
    else
        echo -e "${RED}错误: 安装失败，请检查网络或 npm 配置。${NC}"
        exit 1
    fi
fi

# ---------- 4. 配置文件处理（幂等）----------
echo -e "${YELLOW}[4/5] 配置 Claude Code...${NC}"

mkdir -p ~/.claude

SETTINGS_FILE="$HOME/.claude/settings.json"
CLAUDE_JSON_FILE="$HOME/.claude.json"

# 处理 settings.json
if [ -f "$SETTINGS_FILE" ]; then
    echo -e "${BLUE}配置文件 $SETTINGS_FILE 已存在。${NC}"
    read -r -p "是否覆盖？ [y/N] " OVERWRITE_SETTINGS
    if [[ ! "$OVERWRITE_SETTINGS" =~ ^[Yy]$ ]]; then
        echo -e "${GREEN}✓ 保留现有 settings.json${NC}"
    else
        backup_file "$SETTINGS_FILE"
        WRITE_SETTINGS=true
    fi
else
    WRITE_SETTINGS=true
fi

if [ "$WRITE_SETTINGS" = true ]; then
    cat > "$SETTINGS_FILE" <<EOF
{
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.minimaxi.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "$API_KEY",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": 1,
    "ANTHROPIC_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_SMALL_FAST_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "MiniMax-M2.7"
  }
}
EOF
    echo -e "${GREEN}✓ 已写入 $SETTINGS_FILE${NC}"
fi

# 处理 .claude.json
if [ -f "$CLAUDE_JSON_FILE" ]; then
    echo -e "${BLUE}配置文件 $CLAUDE_JSON_FILE 已存在。${NC}"
    read -r -p "是否覆盖？ [y/N] " OVERWRITE_JSON
    if [[ ! "$OVERWRITE_JSON" =~ ^[Yy]$ ]]; then
        echo -e "${GREEN}✓ 保留现有 .claude.json${NC}"
    else
        backup_file "$CLAUDE_JSON_FILE"
        WRITE_JSON=true
    fi
else
    WRITE_JSON=true
fi

if [ "$WRITE_JSON" = true ]; then
    cat > "$CLAUDE_JSON_FILE" <<EOF
{
  "hasCompletedOnboarding": true
}
EOF
    echo -e "${GREEN}✓ 已写入 $CLAUDE_JSON_FILE${NC}"
fi

# ---------- 5. 验证 ----------
echo -e "${YELLOW}[5/5] 验证安装...${NC}"

if check_command claude; then
    CLAUDE_VERSION=$(claude --version 2>/dev/null | head -1 || echo "未知")
    echo -e "${GREEN}✓ Claude Code 可用，版本: ${CLAUDE_VERSION}${NC}"
else
    echo -e "${RED}警告: claude 命令未找到，请检查 PATH 或重新打开终端。${NC}"
fi

# 完成提示
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}Claude Code 配置完成！${NC}"
echo -e "现在可以在终端运行 ${YELLOW}claude${NC} 启动交互式会话。"
echo -e "如需帮助，运行 ${YELLOW}claude --help${NC}"
echo -e "${GREEN}========================================${NC}"
